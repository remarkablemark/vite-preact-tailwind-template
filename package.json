    "eslint-plugin-tsdoc": "0.5.2",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "postcss": "8.5.20",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
