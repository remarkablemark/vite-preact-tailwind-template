    "@tailwindcss/postcss": "4.2.4",
    "eslint": "10.3.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-tsdoc": "0.5.2",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
